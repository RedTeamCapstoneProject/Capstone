{
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/reset-password.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/js/auth-react.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    // Route POST requests to /reset-password(.html)? to the serverless API handler.
    // This prevents static page responses and ensures form submissions reach the API.
    { "src": "/reset-password(?:\\.html)?", "methods": ["POST"], "dest": "/api/auth/reset-password" },
    // Route GET requests to /reset-password to the static HTML page.
    { "src": "/reset-password", "dest": "/reset-password.html" },
    { "handle": "filesystem" }
  ]
}